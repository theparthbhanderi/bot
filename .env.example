# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI Configuration (supports OpenAI, Anthropic, and compatible APIs)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1  # or your custom endpoint
LLM_MODEL_NAME=gpt-3.5-turbo  # gpt-4, claude-3, etc.

# GNews API (for news search)
GNEWS_API_KEY=your_gnews_api_key_here

# Google Fact Check API
GOOGLE_FACT_CHECK_API_KEY=your_google_fact_check_api_key_here

# Tavily API (for web research)
TAVILY_API_KEY=your_tavily_api_key_here

# Google Cloud Vision API (for OCR)
GOOGLE_CLOUD_VISION_API_KEY=your_google_cloud_vision_api_key_here

# Premium Configuration (optional)
PREMIUM_DAILY_LIMIT=10  # Free queries per day
PREMIUM_USER_IDS=user_id_1,user_id_2  # Comma-separated premium user IDs

# Image Generation API
IMAGE_API_KEY=your_image_api_key_here
